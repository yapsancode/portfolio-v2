# ============================================================================
#  Spotify "now playing" header pill
#  Copy this file to .env.local and fill in the three values below.
#  .env.local is gitignored — never commit real secrets.
#
#  How to get them:
#  1. Create an app at https://developer.spotify.com/dashboard
#       - Add a Redirect URI of exactly:  http://127.0.0.1:8888/callback
#       - Copy the Client ID + Client Secret into the first two vars below.
#  2. Get a refresh token (one-time) by running:
#       node scripts/get-spotify-refresh-token.mjs
#     Follow the printed URL, authorize, and paste the redirected URL back.
#     It prints SPOTIFY_REFRESH_TOKEN — copy it into the third var.
#  3. On Vercel, add all three under Project → Settings → Environment Variables.
# ============================================================================

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
